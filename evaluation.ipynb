{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Evaluasi Model SVM - Prediksi Risiko Stroke"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "Notebook ini berisi tahapan evaluasi model:\n",
    "1. Load model dan data test\n",
    "2. Confusion Matrix\n",
    "3. ROC Curve\n",
    "4. Precision-Recall Curve\n",
    "5. Prediction Distribution\n",
    "6. Model Performance\n",
    "7. Classification Report\n",
    "8. Simpan hasil evaluasi"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "from sklearn.metrics import confusion_matrix, ConfusionMatrixDisplay, classification_report, accuracy_score\n",
    "from sklearn.metrics import roc_curve, auc, precision_recall_curve, average_precision_score\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import joblib\n",
    "import os"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Model dan Data Test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Model dan data test berhasil di-load!\n",
      "X_test shape: (1945, 10)\n",
      "y_test shape: (1945,)\n"
     ]
    }
   ],
   "source": [
    "model = joblib.load('model/svm_model.pkl')\n",
    "X_test = np.load('data/X_test.npy')\n",
    "y_test = np.load('data/y_test.npy')\n",
    "\n",
    "print(\"Model dan data test berhasil di-load!\")\n",
    "print(f\"X_test shape: {X_test.shape}\")\n",
    "print(f\"y_test shape: {y_test.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Prediksi dan Probabilitas"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Accuracy: 0.9136\n"
     ]
    }
   ],
   "source": [
    "y_pred = model.predict(X_test)\n",
    "y_prob = model.decision_function(X_test)\n",
    "\n",
    "accuracy = accuracy_score(y_test, y_pred)\n",
    "print(f\"Accuracy: {accuracy:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Confusion Matrix"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "... (line truncated to 2000 chars)"
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "Confusion Matrix:\n",
      "[[824 149]\n",
      " [ 19 953]]\n"
     ]
    }
   ],
   "source": [
    "os.makedirs('results', exist_ok=True)\n",
    "\n",
    "cm = confusion_matrix(y_test, y_pred)\n",
    "\n",
    "disp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=['No Stroke', 'Stroke'])\n",
    "disp.plot(cmap='Blues')\n",
    "plt.title('Confusion Matrix - SVM Stroke Prediction')\n",
    "plt.savefig('results/confusion_matrix.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"\\nConfusion Matrix:\")\n",
    "print(cm)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. ROC Curve"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "\n",
     "text/plain": [
      "<Figure size 640x480 with 2 Axes>"
     ]
    }
   ],
   "source": [
    "fpr, tpr, thresholds = roc_curve(y_test, y_prob)\n",
    "roc_auc = auc(fpr, tpr)\n",
    "\n",
    "plt.figure(figsize=(8, 6))\n",
    "plt.plot(fpr, tpr, color='darkorange', lw=2, label=f'ROC Curve (AUC = {roc_auc:.4f})')\n",
    "plt.plot([0, 1], [0, 1], color='navy', lw=2, linestyle='--', label='Random Classifier')\n",
    "plt.xlim([0.0, 1.0])\n",
    "plt.ylim([0.0, 1.05])\n",
    "plt.xlabel('False Positive Rate', fontsize=12)\n",
    "plt.ylabel('True Positive Rate', fontsize=12)\n",
    "plt.title('ROC Curve - SVM Stroke Prediction', fontsize=14)\n",
    "plt.legend(loc='lower right', fontsize=10)\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.savefig('results/roc_curve.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(f\"ROC AUC Score: {roc_auc:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Precision-Recall Curve"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "\n",
     "text/plain": [
      "<Figure size 640x480 with 2 Axes>"
     ]
    }
   ],
   "source": [
    "precision, recall, thresholds_pr = precision_recall_curve(y_test, y_prob)\n",
    "avg_precision = average_precision_score(y_test, y_prob)\n",
    "\n",
    "plt.figure(figsize=(8, 6))\n",
    "plt.plot(recall, precision, color='green', lw=2, label=f'Precision-Recall Curve (AP = {avg_precision:.4f})')\n",
    "plt.xlim([0.0, 1.0])\n",
    "plt.ylim([0.0, 1.05])\n",
    "plt.xlabel('Recall', fontsize=12)\n",
    "plt.ylabel('Precision', fontsize=12)\n",
    "plt.title('Precision-Recall Curve - SVM Stroke Prediction', fontsize=14)\n",
    "plt.legend(loc='lower left', fontsize=10)\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.savefig('results/precision_recall_curve.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(f\"Average Precision Score: {avg_precision:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Prediction Distribution"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "\n",
     "text/plain": [
      "<Figure size 640x480 with 2 Axes>"
     ]
    }
   ],
   "source": [
    "plt.figure(figsize=(10, 6))\n",
    "\n",
    "plt.subplot(1, 2, 1)\n",
    "sns.countplot(x=y_pred, palette=['#2ecc71', '#e74c3c'])\n",
    "plt.xticks([0, 1], ['No Stroke', 'Stroke'])\n",
    "plt.xlabel('Predicted Label', fontsize=12)\n",
    "plt.ylabel('Count', fontsize=12)\n",
    "plt.title('Distribution of Predictions', fontsize=14)\n",
    "\n",
    "for i, count in enumerate(np.bincount(y_pred)):\n",
    "    plt.text(i, count + 10, str(count), ha='center', fontsize=11)\n",
    "\n",
    "plt.subplot(1, 2, 2)\n",
    "sns.countplot(x=y_test, palette=['#2ecc71', '#e74c3c'])\n",
    "plt.xticks([0, 1], ['No Stroke', 'Stroke'])\n",
    "plt.xlabel('True Label', fontsize=12)\n",
    "plt.ylabel('Count', fontsize=12)\n",
    "plt.title('Distribution of Actual Labels', fontsize=14)\n",
    "\n",
    "for i, count in enumerate(np.bincount(y_test)):\n",
    "    plt.text(i, count + 10, str(count), ha='center', fontsize=11)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('results/prediction_distribution.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Model Performance"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "\n",
     "text/plain": [
      "<Figure size 640x480 with 2 Axes>"
     ]
    }
   ],
   "source": [
    "from sklearn.metrics import precision_score, recall_score, f1_score\n",
    "\n",
    "precision_no_stroke = precision_score(y_test, y_pred, pos_label=0)\n",
    "recall_no_stroke = recall_score(y_test, y_pred, pos_label=0)\n",
    "f1_no_stroke = f1_score(y_test, y_pred, pos_label=0)\n",
    "\n",
    "precision_stroke = precision_score(y_test, y_pred, pos_label=1)\n",
    "recall_stroke = recall_score(y_test, y_pred, pos_label=1)\n",
    "f1_stroke = f1_score(y_test, y_pred, pos_label=1)\n",
    "\n",
    "metrics = {\n",
    "    'Precision': [precision_no_stroke, precision_stroke],\n",
    "    'Recall': [recall_no_stroke, recall_stroke],\n",
    "    'F1-Score': [f1_no_stroke, f1_stroke]\n",
    "}\n",
    "\n",
    "x = np.arange(2)\n",
    "width = 0.25\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "rects1 = ax.bar(x - width, metrics['Precision'], width, label='Precision', color='#3498db')\n",
    "rects2 = ax.bar(x, metrics['Recall'], width, label='Recall', color='#e74c3c')\n",
    "rects3 = ax.bar(x + width, metrics['F1-Score'], width, label='F1-Score', color='#2ecc71')\n",
    "\n",
    "ax.set_ylabel('Score', fontsize=12)\n",
    "ax.set_title('Model Performance Metrics by Class', fontsize=14)\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels(['No Stroke', 'Stroke'], fontsize=11)\n",
    "ax.legend(fontsize=10)\n",
    "ax.set_ylim([0, 1.1])\n",
    "ax.grid(axis='y', alpha=0.3)\n",
    "\n",
    "def autolabel(rects):\n",
    "    for rect in rects:\n",
    "        height = rect.get_height()\n",
    "        ax.annotate(f'{height:.2f}',\n",
    "                    xy=(rect.get_x() + rect.get_width() / 2, height),\n",
    "                    xytext=(0, 3),\n",
    "                    textcoords=\"offset points\",\n",
    "                    ha='center', va='bottom', fontsize=9)\n",
    "\n",
    "autolabel(rects1)\n",
    "autolabel(rects2)\n",
    "autolabel(rects3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('results/model_performance.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(f\"\\nNo Stroke - Precision: {precision_no_stroke:.4f}, Recall: {recall_no_stroke:.4f}, F1: {f1_no_stroke:.4f}\")\n",
    "print(f\"Stroke    - Precision: {precision_stroke:.4f}, Recall: {recall_stroke:.4f}, F1: {f1_stroke:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Classification Report"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "==================================================\n",
      "       HASIL EVALUASI MODEL SVM\n",
      "==================================================\n",
      "\n",
      "Accuracy  : 0.9136\n",
      "\n",
      "              precision    recall  f1-score   support\n",
      "\n",
      "   No Stroke       0.98      0.85      0.91       973\n",
      "      Stroke       0.86      0.98      0.92       972\n",
      "\n",
      "    accuracy                           0.91      1945\n",
      "   macro avg       0.92      0.91      0.91      1945\n",
      "weighted avg       0.92      0.91      0.91      1945\n",
      "\n"
     ]
    }
   ],
   "source": [
    "print(\"=\" * 50)\n",
    "print(\"       HASIL EVALUASI MODEL SVM\")\n",
    "print(\"=\" * 50)\n",
    "print(f\"\\nAccuracy  : {accuracy:.4f}\")\n",
    "print()\n",
    "\n",
    "report = classification_report(y_test, y_pred, target_names=['No Stroke', 'Stroke'])\n",
    "print(report)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Simpan Classification Report"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Classification report disimpan ke: results/classification_report.txt\n"
     ]
    }
   ],
   "source": [
    "with open('results/classification_report.txt', 'w') as f:\n",
    "    f.write(\"=\" * 50 + \"\\n\")\n",
    "    f.write(\"       HASIL EVALUASI MODEL SVM\\n\")\n",
    "    f.write(\"=\" * 50 + \"\\n\\n\")\n",
    "    f.write(f\"Accuracy  : {accuracy:.4f}\\n\")\n",
    "    f.write(f\"ROC AUC   : {roc_auc:.4f}\\n\")\n",
    "    f.write(f\"Avg Precision: {avg_precision:.4f}\\n\\n\")\n",
    "    f.write(report)\n",
    "\n",
    "print(\"Classification report disimpan ke: results/classification_report.txt\")\n",
    "print(\"\\nSemua hasil evaluasi telah disimpan di folder 'results/'!\")"
   ]
  }
