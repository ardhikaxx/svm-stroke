    "axes[1, 1].set_title('Prediction Accuracy', fontsize=14, fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('results/prediction_distribution.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Model Performance Metrics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": ""
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "precision_no_stroke = precision_score(y_test, y_pred, pos_label=0)\n",
    "recall_no_stroke = recall_score(y_test, y_pred, pos_label=0)\n",
    "f1_no_stroke = f1_score(y_test, y_pred, pos_label=0)\n",
    "\n",
    "precision_stroke = precision_score(y_test, y_pred, pos_label=1)\n",
    "recall_stroke = recall_score(y_test, y_pred, pos_label=1)\n",
    "f1_stroke = f1_score(y_test, y_pred, pos_label=1)\n",
    "\n",
    "metrics = {\n",
    "    'Precision': [precision_no_stroke, precision_stroke],\n",
    "    'Recall': [recall_no_stroke, recall_stroke],\n",
    "    'F1-Score': [f1_no_stroke, f1_stroke]\n",
    "}\n",
    "\n",
    "x = np.arange(2)\n",
    "width = 0.25\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "rects1 = axes[0].bar(x - width, metrics['Precision'], width, label='Precision', color='#3498db')\n",
    "rects2 = axes[0].bar(x, metrics['Recall'], width, label='Recall', color='#e74c3c')\n",
    "rects3 = axes[0].bar(x + width, metrics['F1-Score'], width, label='F1-Score', color='#2ecc71')\n",
    "\n",
    "axes[0].set_ylabel('Score', fontsize=12)\n",
    "axes[0].set_title('Performance Metrics by Class', fontsize=14, fontweight='bold')\n",
    "axes[0].set_xticks(x)\n",
    "axes[0].set_xticklabels(['No Stroke', 'Stroke'], fontsize=11)\n",
    "axes[0].legend(fontsize=10)\n",
    "axes[0].set_ylim([0, 1.15])\n",
    "axes[0].grid(axis='y', alpha=0.3)\n",
    "\n",
    "def autolabel(rects, ax):\n",
    "    for rect in rects:\n",
    "        height = rect.get_height()\n",
    "        ax.annotate(f'{height:.2f}',\n",
    "                    xy=(rect.get_x() + rect.get_width() / 2, height),\n",
    "                    xytext=(0, 3),\n",
    "                    textcoords=\"offset points\",\n",
    "                    ha='center', va='bottom', fontsize=9)\n",
    "\n",
    "autolabel(rects1, axes[0])\n",
    "autolabel(rects2, axes[0])\n",
    "autolabel(rects3, axes[0])\n",
    "\n",
    "overall_metrics = {\n",
    "    'Accuracy': accuracy,\n",
    "    'ROC AUC': roc_auc,\n",
    "    'Avg Precision': avg_precision,\n",
    "    'Macro F1': f1_score(y_test, y_pred, average='macro'),\n",
    "    'Weighted F1': f1_score(y_test, y_pred, average='weighted')\n",
    "}\n",
    "\n",
    "colors_metrics = ['#3498db', '#e74c3c', '#2ecc71', '#9b59b6', '#f39c12']\n",
    "bars = axes[1].barh(list(overall_metrics.keys()), list(overall_metrics.values()), color=colors_metrics, edgecolor='black')\n",
    "axes[1].set_xlim([0, 1.1])\n",
    "axes[1].set_xlabel('Score', fontsize=12)\n",
    "axes[1].set_title('Overall Model Metrics', fontsize=14, fontweight='bold')\n",
    "axes[1].grid(axis='x', alpha=0.3)\n",
    "\n",
    "for bar, value in zip(bars, overall_metrics.values()):\n",
    "    axes[1].text(value + 0.02, bar.get_y() + bar.get_height()/2, f'{value:.4f}', va='center', fontsize=10)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('results/model_performance.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(f\"\\nNo Stroke - Precision: {precision_no_stroke:.4f}, Recall: {recall_no_stroke:.4f}, F1: {f1_no_stroke:.4f}\")\n",
    "print(f\"Stroke    - Precision: {precision_stroke:.4f}, Recall: {recall_stroke:.4f}, F1: {f1_stroke:.4f}\")\n",
    "print(f\"\\nOverall Metrics:\")\n",
    "for metric, value in overall_metrics.items():\n",
    "    print(f\"  {metric}: {value:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Error Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": ""
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "errors = y_test != y_pred\n",
    "error_indices = np.where(errors)[0]\n",
    "\n",
    "fp_indices = np.where((y_pred == 1) & (y_test == 0))[0]\n",
    "fn_indices = np.where((y_pred == 0) & (y_test == 1))[0]\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(16, 5))\n",
    "\n",
    "error_types = ['False Positive\\n(No Stroke → Stroke)', 'False Negative\\n(Stroke → No Stroke)', 'Total Errors']\n",
    "error_counts = [len(fp_indices), len(fn_indices), len(error_indices)]\n",
    "colors_error = ['#e74c3c', '#f39c12', '#9b59b6']\n",
    "\n",
    "bars = axes[0].bar(error_types, error_counts, color=colors_error, edgecolor='black', linewidth=1.5)\n",
    "axes[0].set_title('Error Distribution', fontsize=14, fontweight='bold')\n",
    "axes[0].set_ylabel('Count', fontsize=11)\n",
    "for bar, count in zip(bars, error_counts):\n",
    "    axes[0].text(bar.get_x() + bar.get_width()/2, bar.get_height() + 2, str(count), ha='center', fontsize=12, fontweight='bold')\n",
    "\n",
    "labels_error = ['True Negative', 'False Positive', 'False Negative', 'True Positive']\n",
    "cm_flat = cm.flatten()\n",
    "colors_pie = ['#2ecc71', '#e74c3c', '#f39c12', '#3498db']\n",
    "axes[1].pie(cm_flat, labels=labels_error, colors=colors_pie, autopct='%1.1f%%', startangle=90, explode=(0, 0.1, 0.1, 0))\n",
    "axes[1].set_title('Confusion Matrix Proportion', fontsize=14, fontweight='bold')\n",
    "\n",
    "y_error = y_prob[errors]\n",
    "y_correct = y_prob[~errors]\n",
    "\n",
    "axes[2].hist(y_correct, bins=50, alpha=0.7, label=f'Correct ({len(y_correct)})', color='#2ecc71', edgecolor='black')\n",
    "axes[2].hist(y_error, bins=50, alpha=0.7, label=f'Incorrect ({len(y_error)})', color='#e74c3c', edgecolor='black')\n",
    "axes[2].axvline(x=0, color='black', linestyle='--', lw=2, label='Decision Boundary')\n",
    "axes[2].set_title('Decision Score Distribution (Errors vs Correct)', fontsize=14, fontweight='bold')\n",
    "axes[2].set_xlabel('Decision Function Score', fontsize=11)\n",
    "axes[2].set_ylabel('Frequency', fontsize=11)\n",
    "axes[2].legend(fontsize=10)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('results/error_analysis.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(f\"\\nTotal Errors: {len(error_indices)}\")\n",
    "print(f\"False Positives (No Stroke diprediksi Stroke): {len(fp_indices)}\")\n",
    "print(f\"False Negatives (Stroke diprediksi No Stroke): {len(fn_indices)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Cross-Validation Results"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": ""
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n",
    "\n",
    "cv_accuracy = cross_val_score(model, X_train, y_train, cv=cv, scoring='accuracy')\n",
    "cv_f1 = cross_val_score(model, X_train, y_train, cv=cv, scoring='f1')\n",
    "cv_roc_auc = cross_val_score(model, X_train, y_train, cv=cv, scoring='roc_auc')\n",
    "cv_precision = cross_val_score(model, X_train, y_train, cv=cv, scoring='precision')\n",
    "cv_recall = cross_val_score(model, X_train, y_train, cv=cv, scoring='recall')\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "folds = range(1, 6)\n",
    "axes[0].plot(folds, cv_accuracy, 'o-', label='Accuracy', lw=2, markersize=8)\n",
    "axes[0].plot(folds, cv_f1, 's-', label='F1-Score', lw=2, markersize=8)\n",
    "axes[0].plot(folds, cv_roc_auc, '^-', label='ROC AUC', lw=2, markersize=8)\n",
    "axes[0].plot(folds, cv_precision, 'D-', label='Precision', lw=2, markersize=8)\n",
    "axes[0].plot(folds, cv_recall, 'v-', label='Recall', lw=2, markersize=8)\n",
    "axes[0].set_xlabel('Fold', fontsize=12)\n",
    "axes[0].set_ylabel('Score', fontsize=12)\n",
