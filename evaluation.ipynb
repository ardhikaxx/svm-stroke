    "    'Precision': cv_precision,\n",
    "    'Recall': cv_recall\n",
    "}\n",
    "\n",
    "bp = axes[1].boxplot([cv_accuracy, cv_f1, cv_roc_auc, cv_precision, cv_recall],\n",
