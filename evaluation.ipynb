    "axes[0].legend(loc='best', fontsize=10)\n",
    "axes[0].set_ylim([0.7, 1.0])\n",
    "axes[0].grid(True, alpha=0.3)\n",
    "axes[0].set_xticks(folds)\n",
    "\n",
    "cv_results = {\n",
    "    'Accuracy': cv_accuracy,\n",
    "    'F1-Score': cv_f1,\n",
